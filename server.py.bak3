  border:1px solid #1e1e28;position:relative}
.hero img{width:100%;height:200px;object-fit:cover;display:block}
.hero-placeholder{width:100%;height:200px;display:flex;align-items:center;
  justify-content:center;font-size:48px}
.hero-body{padding:14px 16px}
.hero-body h2{font-size:17px;font-weight:600;line-height:1.35;margin-bottom:6px}
