body{background:#08080c;color:#e0dcd4;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  font-size:15px;line-height:1.5;-webkit-font-smoothing:antialiased}
a{color:#e0dcd4;text-decoration:none}
.wrap{max-width:640px;margin:0 auto;padding:0 12px 40px}
header{padding:16px 0 8px;text-align:center}
header h1{font-size:20px;font-weight:700;color:#c9a84c;letter-spacing:1px}
header p{font-size:12px;color:#777;margin-top:2px}
.sticky{position:sticky;top:0;z-index:100;background:#08080c;padding:8px 0 4px;
  border-bottom:1px solid #1a1a22}
