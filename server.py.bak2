.new-badge{font-size:.55rem;padding:.1rem .4rem;border-radius:6px;background:rgba(80,200,120,.15);color:#50c878;font-weight:600;text-transform:uppercase;letter-spacing:.05em}

/* Date separator */
.date-sep{font-size:.65rem;color:#c9a84c;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:1rem 0 .3rem}

/* Empty state */
.empty{text-align:center;color:#555;padding:3rem;font-size:.85rem}
.empty a{color:#c9a84c}

/* Responsive tweaks */
@media(max-width:400px){
