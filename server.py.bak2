# CSS
# ---------------------------------------------------------------------------

CSS = """
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:system-ui,-apple-system,sans-serif;background:#08080c;color:#e0dcd4;min-height:100vh;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
.w{max-width:640px;margin:0 auto;padding:.8rem .8rem 4rem}

/* Header */
.hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;padding-bottom:.6rem;border-bottom:1px solid #1a1a24}
.hd h1{font-size:1.15rem;font-weight:700;letter-spacing:-.01em}
.hd h1 .cnt{opacity:.35;font-weight:400;font-size:.7rem;margin-left:.3rem}
.rf{font-size:.65rem;color:#666;border:1px solid #1a1a24;padding:.35rem .7rem;border-radius:6px;transition:all .2s}
.rf:hover{color:#c9a84c;border-color:#c9a84c}

/* Sticky Filter Bar */
.filters{position:sticky;top:0;z-index:10;background:#08080c;padding:.5rem 0;margin-bottom:.8rem}
.bar{display:flex;gap:.35rem;overflow-x:auto;scrollbar-width:none;padding-bottom:.25rem}
.bar::-webkit-scrollbar{display:none}
.chip{white-space:nowrap;padding:.35rem .7rem;border-radius:16px;border:1px solid #1a1a24;color:#666;font-size:.7rem;flex-shrink:0;transition:all .2s;cursor:pointer}
.chip:hover,.chip.on{color:#c9a84c;border-color:#c9a84c;background:rgba(201,168,76,.08)}
.chip.brand-chip{font-size:.65rem}
.chip.brand-chip.on{color:#4a9eff;border-color:#4a9eff;background:rgba(74,158,255,.08)}

/* Hero */
.hero{background:#0e0e14;border-radius:12px;overflow:hidden;margin-bottom:1.2rem;border:1px solid #1a1a24;transition:border-color .2s}
.hero:hover{border-color:#c9a84c}
.hero-img{width:100%;aspect-ratio:16/9;overflow:hidden;position:relative}
.hero-img img{width:100%;height:100%;object-fit:cover}
.hero-img.placeholder{display:flex;align-items:center;justify-content:center}
.hero-icon{font-size:3rem}
.hero-body{padding:1rem}
.hero-top{display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem}
.hero-label{font-size:.6rem;text-transform:uppercase;letter-spacing:.1em;color:#c9a84c;font-weight:600}
.hero h2{font-size:1.05rem;line-height:1.4;font-weight:600;margin-bottom:.4rem}
.hero .summary{font-size:.78rem;color:#999;line-height:1.5;margin-bottom:.6rem}
.hero .meta{display:flex;gap:.4rem;flex-wrap:wrap;align-items:center}

/* Trending */
.section-title{font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:#c9a84c;font-weight:600;margin:1.2rem 0 .6rem;display:flex;align-items:center;gap:.4rem}
.trending-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.6rem;margin-bottom:1.2rem}
.trend-card{background:#0e0e14;border-radius:10px;overflow:hidden;border:1px solid #1a1a24;transition:all .2s}
.trend-card:hover{border-color:#c9a84c;transform:translateY(-1px)}
.trend-card .card-img{width:100%;aspect-ratio:4/3;overflow:hidden;position:relative}
.trend-card .card-img img{width:100%;height:100%;object-fit:cover}
.trend-card .card-img.placeholder{display:flex;align-items:center;justify-content:center}
.trend-card .card-img.placeholder span{font-size:1.5rem}
.trend-body{padding:.55rem}
.trend-body .title{font-size:.75rem;line-height:1.35;font-weight:500;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.trend-body .tmeta{display:flex;gap:.3rem;margin-top:.35rem;flex-wrap:wrap;align-items:center}

/* Feed Cards */
.feed-card{display:flex;gap:.7rem;padding:.65rem 0;border-bottom:1px solid #111;transition:background .15s;border-radius:6px;padding-left:.3rem;padding-right:.3rem}
.feed-card:hover{background:rgba(201,168,76,.03)}
.feed-card .card-img{width:100px;min-width:100px;height:70px;border-radius:8px;overflow:hidden;flex-shrink:0}
