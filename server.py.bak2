"""P22 GADGETFINDER -- Gadget-Discovery-Tool. Was ist HOT? Was ist NEU?"""
import json, os, time, re, hashlib, sqlite3
from pathlib import Path
from datetime import datetime, timezone, timedelta
from html import escape
from fastapi import FastAPI, Query, Request
from fastapi.responses import HTMLResponse, Response
import uvicorn

BASE = Path(__file__).parent
DB_PATH = BASE / "data" / "gadgets.db"
FEEDS_PATH = BASE / "data" / "feeds.json"

app = FastAPI()

# ---------------------------------------------------------------------------
# DB
# ---------------------------------------------------------------------------

def get_db():
    db = sqlite3.connect(str(DB_PATH))
    db.row_factory = sqlite3.Row
    db.execute("PRAGMA journal_mode=WAL")
    return db

def init_db():
    db = get_db()
    db.executescript("""
        CREATE TABLE IF NOT EXISTS articles (
            id TEXT PRIMARY KEY,
            title TEXT NOT NULL,
            url TEXT NOT NULL,
            source TEXT NOT NULL,
            category TEXT DEFAULT 'gadgets',
            brand TEXT,
            summary TEXT,
            image_url TEXT,
            published TEXT,
            fetched TEXT,
            score INTEGER DEFAULT 0
        );
        CREATE INDEX IF NOT EXISTS idx_published ON articles(published DESC);
        CREATE INDEX IF NOT EXISTS idx_category ON articles(category);
    """)
    db.close()

init_db()

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

def load_config():
    with open(FEEDS_PATH) as f:
        return json.load(f)

CAT_ICONS = {
    "audio": "🎧", "wearables": "⌚", "mobile": "📱", "smarthome": "🏠",
    "gaming": "🎮", "power": "🔋", "desk": "🖥️", "gadgets": "📦",
}
CAT_LABELS = {
    "audio": "Audio", "wearables": "Wearables", "mobile": "Mobile",
    "smarthome": "Smart Home", "gaming": "Gaming", "power": "Power & Laden",
    "desk": "Desk Setup", "gadgets": "Gadgets",
}
CAT_GRADIENTS = {
    "audio": "linear-gradient(135deg,#1a1a3e,#2d1b4e)",
    "wearables": "linear-gradient(135deg,#1a2a1a,#1b3a2e)",
    "mobile": "linear-gradient(135deg,#2a1a1a,#3a1b2e)",
    "smarthome": "linear-gradient(135deg,#1a2a2a,#1b3a3e)",
    "gaming": "linear-gradient(135deg,#2a1a2a,#3a1b3e)",
    "power": "linear-gradient(135deg,#2a2a1a,#3a3a1b)",
    "desk": "linear-gradient(135deg,#1a1a2a,#2b2b3e)",
    "gadgets": "linear-gradient(135deg,#1a1a1a,#2a2a2a)",
}

# ---------------------------------------------------------------------------
# Score -- neu berechnet bei jedem Render
# ---------------------------------------------------------------------------

SCORE_BOOSTER_WORDS = ["review", "test", "hands-on", "unboxing", "vs", "comparison",
                       "best", "top", "versus", "rated", "ranking", "benchmark"]

def compute_score(row, config):
    """Berechne Score dynamisch aus Artikeldaten."""
    score = 0
    title_lower = (row["title"] or "").lower()
    summary_lower = (row["summary"] or "").lower()
    text = title_lower + " " + summary_lower

    # Brand match
    for b in config.get("brands_watchlist", []):
        if b.lower() in text:
            score += 20
            break

    # Kategorie-Keywords
    kw_hits = 0
    for cat, kws in config.get("keywords", {}).items():
        for kw in kws:
            if kw in text:
                kw_hits += 1
    score += min(kw_hits, 5) * 10

    # Tier
    source = (row["source"] or "").lower()
    tier_map = {}
    for f in config.get("feeds", []):
        tier_map[f["name"].lower()] = f.get("tier", 3)
    tier = tier_map.get(source, 3)
    if tier == 1:
        score += 15
    elif tier == 2:
        score += 10
    else:
        score += 5

    # Hat Bild
    if row["image_url"]:
        score += 10

    # Review/Test Booster
    for word in SCORE_BOOSTER_WORDS:
        if word in title_lower:
            score += 15
            break

    # best/top/vs/comparison in title
    for word in ["best", "top", "vs", "comparison", "versus"]:
        if word in title_lower:
            score += 10
            break

    return score

# ---------------------------------------------------------------------------
# Kategorie -- verbessert, Multi-Match, catch-all nur wenn nix passt
# ---------------------------------------------------------------------------

def assign_category(title, summary, config):
    """Bessere Kategorie-Zuordnung. 'gadgets' nur als Fallback."""
    text = (title + " " + summary).lower()
    scores = {}
    for cat, kws in config.get("keywords", {}).items():
        if cat == "gadgets":
            continue
        cat_score = 0
        for kw in kws:
            if kw in text:
                cat_score += 1
        if cat_score > 0:
            scores[cat] = cat_score
    if not scores:
        return "gadgets"
    return max(scores, key=scores.get)

# ---------------------------------------------------------------------------
# Fetch mit og:image Nachladen
# ---------------------------------------------------------------------------

def try_fetch_og_image(url):
    """Versuche og:image von der Artikel-URL zu holen."""
    try:
        import requests
        from bs4 import BeautifulSoup
        resp = requests.get(url, timeout=5, headers={
            "User-Agent": "Mozilla/5.0 (compatible; Gadgetfinder/1.0)"
        })
        if resp.status_code == 200:
            soup = BeautifulSoup(resp.text[:50000], "html.parser")
            og = soup.find("meta", property="og:image")
            if og and og.get("content"):
                return og["content"]
    except Exception:
        pass
    return ""

def fetch_feeds():
    import feedparser
    config = load_config()
    keywords = config["keywords"]
    brands = [b.lower() for b in config["brands_watchlist"]]
    db = get_db()
    new_count = 0
    for feed_cfg in config["feeds"]:
        try:
            feed = feedparser.parse(feed_cfg["url"])
            for entry in feed.entries[:30]:
                title = entry.get("title", "").strip()
                url = entry.get("link", "").strip()
                if not title or not url:
                    continue
                art_id = hashlib.md5(url.encode()).hexdigest()[:16]
                if db.execute("SELECT 1 FROM articles WHERE id=?", (art_id,)).fetchone():
                    continue

                summary = entry.get("summary", "")[:500] or ""
                text = (title + " " + summary).lower()

                # Noise-Filter: Deals, How-tos, News-Roundups raus
                noise_patterns = config.get("noise_patterns", [])
                is_noise = False
                for np in noise_patterns:
                    if np in text:
                        is_noise = True
                        break
                if is_noise:
                    # Trotzdem rein wenn starkes Produkt-Signal
                    product_hits = sum(1 for ps in config.get("product_signals", []) if ps in text)
                    if product_hits < 2:
                        continue

                # Relevanz-Check: mindestens ein Keyword oder Brand muss matchen
                matched = False
                matched_brand = None
                for b in brands:
                    if b in text:
                        matched_brand = b.title()
                        matched = True
                        break
                if not matched:
                    for cat, cat_kws in keywords.items():
                        for kw in cat_kws:
                            if kw in text:
                                matched = True
                                break
                        if matched:
                            break
                if not matched:
                    continue

                # Kategorie
                matched_cat = assign_category(title, summary, config)

                # Published
                pub = ""
                if hasattr(entry, "published_parsed") and entry.published_parsed:
                    try:
                        pub = datetime(*entry.published_parsed[:6]).isoformat()
                    except Exception:
                        pass
                if not pub:
                    pub = datetime.now(timezone.utc).isoformat()

                # Bild: Feed-Medien, dann og:image
                img = ""
                if hasattr(entry, "media_content") and entry.media_content:
                    img = entry.media_content[0].get("url", "")
                elif hasattr(entry, "media_thumbnail") and entry.media_thumbnail:
                    img = entry.media_thumbnail[0].get("url", "")
                if not img:
                    img = try_fetch_og_image(url)

                db.execute(
                    """INSERT OR IGNORE INTO articles
                    (id,title,url,source,category,brand,summary,image_url,published,fetched,score)
                    VALUES (?,?,?,?,?,?,?,?,?,?,?)""",
                    (art_id, title, url, feed_cfg["name"], matched_cat, matched_brand,
                     summary[:300], img, pub, datetime.now(timezone.utc).isoformat(), 0))
                new_count += 1
        except Exception as e:
            print(f"Feed error {feed_cfg['name']}: {e}")
    db.commit()
    db.close()
    return new_count

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def date_label(date_str):
    try:
        d = datetime.fromisoformat(date_str.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        if d.date() == now.date():
            return "Heute"
        if d.date() == (now - timedelta(days=1)).date():
            return "Gestern"
        return d.strftime("%d. %B %Y")
    except Exception:
        return ""

def is_new(date_str):
    try:
        d = datetime.fromisoformat(date_str.replace("Z", "+00:00"))
        return (datetime.now(timezone.utc) - d) < timedelta(hours=24)
    except Exception:
        return False

def score_badge(s):
    if s >= 80:
        return f'<span class="score hot">🔥 {s}</span>'
    if s >= 60:
        return f'<span class="score good">⭐ {s}</span>'
    if s >= 40:
        return f'<span class="score mid">● {s}</span>'
    return f'<span class="score low">● {s}</span>'

def truncate(text, length=120):
    text = re.sub(r"<[^>]+>", "", text or "")
    text = text.strip()
    if len(text) > length:
        return text[:length].rsplit(" ", 1)[0] + "..."
    return text

def img_html_feed(row):
    """Bild fuer Feed-Karten (120x80)."""
    url = row["image_url"]
    cat = row["category"] or "gadgets"
    if url:
        return f'<div class="card-img"><img src="{escape(url)}" alt="" loading="lazy"></div>'
    gradient = CAT_GRADIENTS.get(cat, CAT_GRADIENTS["gadgets"])
    icon = CAT_ICONS.get(cat, "📦")
    return f'<div class="card-img placeholder" style="background:{gradient}"><span>{icon}</span></div>'

def img_html_hero(row):
    """Bild fuer Hero (volle Breite)."""
    url = row["image_url"]
    cat = row["category"] or "gadgets"
    if url:
        return f'<div class="hero-img"><img src="{escape(url)}" alt="" loading="lazy"></div>'
    gradient = CAT_GRADIENTS.get(cat, CAT_GRADIENTS["gadgets"])
    icon = CAT_ICONS.get(cat, "📦")
    return f'<div class="hero-img placeholder" style="background:{gradient}"><span class="hero-icon">{icon}</span></div>'

