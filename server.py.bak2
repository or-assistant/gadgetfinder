.feed-card .title{font-size:.8rem;line-height:1.35;font-weight:500;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;transition:color .15s}
.feed-card:hover .title{color:#c9a84c}
.feed-card .snippet{font-size:.68rem;color:#777;line-height:1.4;margin-top:.2rem;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}
.feed-card .fmeta{display:flex;gap:.3rem;margin-top:.3rem;flex-wrap:wrap;align-items:center}

/* Pills & Badges */
.pill{font-size:.58rem;padding:.15rem .45rem;border-radius:8px;display:inline-flex;align-items:center}
