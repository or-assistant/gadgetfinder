"""

# ---------------------------------------------------------------------------
# Routes
# ---------------------------------------------------------------------------

@app.get("/", response_class=HTMLResponse)
async def index(request: Request, cat: str = Query("all"), brand: str = Query("")):
    db = get_db()
    config = load_config()

    # Alle Artikel laden (noise wird beim Fetch schon gefiltert, score >= 0)
    rows = db.execute("SELECT * FROM articles WHERE score >= 0 ORDER BY published DESC LIMIT 200").fetchall()
    total = db.execute("SELECT COUNT(*) FROM articles WHERE score >= 0").fetchone()[0]
    db.close()

    # Score dynamisch berechnen
    articles = []
    for r in rows:
        a = dict(r)
        a["_score"] = compute_score(a, config)
        articles.append(a)

    # Filter anwenden
    if brand:
        articles = [a for a in articles if a["brand"] and brand.lower() in a["brand"].lower()]
    elif cat != "all":
        articles = [a for a in articles if a["category"] == cat]

    # Sortierungen
    by_score = sorted(articles, key=lambda a: a["_score"], reverse=True)
    by_date = sorted(articles, key=lambda a: a.get("published", ""), reverse=True)

    categories = [c for c in config["keywords"].keys()]
    brands_list = config["brands_watchlist"][:14]

    # --- Hero: Top Gadget (hoechster Score) ---
    hero_html = ""
    if by_score and not brand:
        h = by_score[0]
        new_b = '<span class="new-badge">Neu</span>' if is_new(h.get("published", "")) else ""
        brand_p = f'<span class="pill brand">{escape(h["brand"])}</span>' if h["brand"] else ""
        src_p = f'<span class="pill src">{escape(h["source"])}</span>'
        summary_t = truncate(h.get("summary", ""), 180)
        hero_html = f'''<a href="{escape(h["url"])}" target="_blank" rel="noopener" class="hero">
{img_html_hero(h)}
<div class="hero-body">
<div class="hero-top"><span class="hero-label">Top Gadget</span>{new_b}{score_badge(h["_score"])}</div>
<h2>{escape(h["title"])}</h2>
<p class="summary">{escape(summary_t)}</p>
<div class="meta">{brand_p}{src_p}<span class="pill cat">{CAT_ICONS.get(h["category"],"📦")} {CAT_LABELS.get(h["category"],"Gadgets")}</span></div>
</div></a>'''

    # --- Trending: Top 4 nach Score (skip Hero) ---
    trending_html = ""
    trending_items = by_score[1:5] if len(by_score) > 1 and not brand else []
    if trending_items:
        cards = ""
        for t in trending_items:
            new_b = '<span class="new-badge">Neu</span>' if is_new(t.get("published", "")) else ""
            brand_p = f'<span class="pill brand">{escape(t["brand"])}</span>' if t["brand"] else ""
            cards += f'''<a href="{escape(t["url"])}" target="_blank" rel="noopener" class="trend-card">
<div class="card-img">{"" if not t["image_url"] else f'<img src="{escape(t["image_url"])}" alt="" loading="lazy">'}</div>
{f'<div class="card-img placeholder" style="background:{CAT_GRADIENTS.get(t["category"], CAT_GRADIENTS["gadgets"])}"><span>{CAT_ICONS.get(t["category"], "📦")}</span></div>' if not t["image_url"] else ""}
<div class="trend-body">
<div class="title">{escape(t["title"])}</div>
<div class="tmeta">{score_badge(t["_score"])}{new_b}{brand_p}<span class="pill src">{escape(t["source"])}</span></div>
</div></a>'''
        trending_html = f'<div class="section-title">🔥 Trending</div><div class="trending-grid">{cards}</div>'

    # --- Feed: chronologisch ---
    feed_html = ""
    # Skip Hero + Trending Artikel im Feed
    hero_trending_ids = set()
    if by_score and not brand:
        for a in by_score[:5]:
            hero_trending_ids.add(a["id"])

    feed_articles = [a for a in by_date if a["id"] not in hero_trending_ids]

    prev_date = ""
    for a in feed_articles[:60]:
        label = date_label(a.get("published", ""))
        if label and label != prev_date:
            feed_html += f'<div class="date-sep">{label}</div>'
            prev_date = label

        new_b = ' <span class="new-badge">Neu</span>' if is_new(a.get("published", "")) else ""
        brand_p = f'<span class="pill brand">{escape(a["brand"])}</span>' if a["brand"] else ""
        src_p = f'<span class="pill src">{escape(a["source"])}</span>'
        cat_p = f'<span class="pill cat">{CAT_ICONS.get(a["category"], "📦")}</span>'
        snippet = truncate(a.get("summary", ""), 80)

        feed_html += f'''<a href="{escape(a["url"])}" target="_blank" rel="noopener" class="feed-card" data-cat="{a["category"]}" data-brand="{escape(a.get("brand","") or "")}">
{img_html_feed(a)}
<div class="card-body">
<div class="title">{escape(a["title"])}</div>
<div class="snippet">{escape(snippet)}</div>
<div class="fmeta">{score_badge(a["_score"])}{new_b}{cat_p}{brand_p}{src_p}</div>
</div></a>'''

    if not feed_html and not hero_html:
        feed_html = '<div class="empty">Keine Artikel gefunden. <a href="/refresh">Feeds laden</a></div>'

    # --- Filter Chips ---
    cat_on = "  on" if cat == "all" and not brand else ""
    cat_chips = f'<a class="chip{cat_on}" href="#" data-filter="cat" data-val="all">Alle</a>'
    for c in categories:
        active = " on" if c == cat and not brand else ""
        label = CAT_LABELS.get(c, c.title())
        icon = CAT_ICONS.get(c, "")
        cat_chips += f'<a class="chip{active}" href="#" data-filter="cat" data-val="{c}">{icon} {label}</a>'

    brand_chips = ""
    for b in brands_list:
        active = " on" if brand and b.lower() == brand.lower() else ""
        brand_chips += f'<a class="chip brand-chip{active}" href="#" data-filter="brand" data-val="{escape(b)}">{escape(b)}</a>'

    feed_section = f'<div class="section-title">📰 Alle Artikel</div>{feed_html}' if feed_articles else feed_html

    return HTMLResponse(f"""<!DOCTYPE html><html lang="de"><head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="robots" content="noindex,nofollow">
<title>Gadgetfinder</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎧</text></svg>">
<style>{CSS}</style></head><body>
<div class="w">
<div class="hd"><h1>🎧 Gadgetfinder<span class="cnt">{total} Artikel</span></h1><a href="/refresh" class="rf">↻ Aktualisieren</a></div>
<div class="filters">
<div class="bar">{cat_chips}</div>
<div class="bar">{brand_chips}</div>
</div>
{hero_html}
{trending_html}
{feed_section}
</div>
<script>
document.addEventListener('click',function(e){{
  var t=e.target.closest('[data-filter]');
  if(!t)return;
  e.preventDefault();
  var type=t.dataset.filter,val=t.dataset.val;
  if(type==='cat'){{
    document.querySelectorAll('.chip:not(.brand-chip)').forEach(function(c){{c.classList.remove('on')}});
    t.classList.add('on');
    document.querySelectorAll('.brand-chip').forEach(function(c){{c.classList.remove('on')}});
    document.querySelectorAll('.feed-card').forEach(function(card){{
      card.style.display=(val==='all'||card.dataset.cat===val)?'':'none';
    }});
  }}else{{
    document.querySelectorAll('.brand-chip').forEach(function(c){{c.classList.remove('on')}});
    t.classList.add('on');
    document.querySelectorAll('.chip:not(.brand-chip)').forEach(function(c){{c.classList.remove('on')}});
    document.querySelectorAll('.feed-card').forEach(function(card){{
      card.style.display=(card.dataset.brand&&card.dataset.brand.toLowerCase().indexOf(val.toLowerCase())>=0)?'':'none';
    }});
  }}
  document.querySelectorAll('.date-sep').forEach(function(sep){{
    var next=sep.nextElementSibling,vis=false;
    while(next&&!next.classList.contains('date-sep')){{
      if(next.classList.contains('feed-card')&&next.style.display!=='none')vis=true;
      next=next.nextElementSibling;
    }}
    sep.style.display=vis?'':'none';
  }});
}});
</script>
</body></html>""")


@app.get("/refresh")
async def refresh():
    n = fetch_feeds()
    return Response(status_code=303, headers={"Location": f"/?refreshed={n}"})


@app.get("/api/health")
async def health():
    db = get_db()
    total = db.execute("SELECT COUNT(*) FROM articles").fetchone()[0]
    db.close()
    return {"status": "ok", "articles": total}


if __name__ == "__main__":
    print("Feeds laden...")
    n = fetch_feeds()
    print(f"{n} neue Artikel geladen")
    uvicorn.run("server:app", host="127.0.0.1", port=3023, reload=False)
